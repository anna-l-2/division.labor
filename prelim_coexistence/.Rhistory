combined<-as.character(Time)
combined<-as.character(combined$Time)
ggplot(combined, aes(x=Time, y=OD600, group = Time, color = Type)) +geom_boxplot()+labs(color = "Type")+ theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) + scale_y_continuous(breaks = seq(0, 6, by = .5))+scale_color_manual(values=c("firebrick3", "burlywood3", "black"))+theme(legend.position = "bottom")
phetyr.short <- subset(
coexist.phetyr.c,
!(Time %in% c("Day 10","Day 14", "Day 15", "Day 16", "Day 17", "Day 18"))
)
combined  <- rbind(coexist.ser, phetyr.short)
combined
combined$Time<-rep("1","2", each=14)
combined
combined$TimeN<-rep("1","3","5","7","8","11","12","13" each=4)
combined$TimeN<-rep("1","3","5","7","8","11","12","13", each=4)
combined$TimeN<-rep("1","3","5","7","8","11","12","13", each=14)
ggplot(combined, aes(x=Time, y=OD600, group = Time, color = Type)) +geom_boxplot()+labs(color = "Type")+ theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) + scale_y_continuous(breaks = seq(0, 6, by = .5))+scale_color_manual(values=c("firebrick3", "burlywood3", "black"))+theme(legend.position = "bottom")
day8.c <- combined %>%
filter(Time == "Day 8")
ggplot(day8.c, aes(x=Type, y=OD600, color = Type)) +geom_boxplot() + scale_y_continuous(breaks = seq(0, 3, by = .5))+scale_color_manual(values=c("firebrick3", "burlywood3", "black"))+ scale_x_discrete(labels = c("Phenylalanine-Tyrosine", "Serine-Phenylalanine", "Serine-Tyrosine"))+
theme(legend.position = "none")+
stat_compare_means(
comparisons = list(
c("PheTyr", "SerPhe"),
c("PheTyr", "SerTyr"),
c("SerPhe", "SerTyr")
),
method = "t.test",
label = "p.signif"
)
