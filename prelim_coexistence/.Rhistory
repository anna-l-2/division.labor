min_OD600 = min(OD600, na.rm = TRUE),
max_OD600 = max(OD600, na.rm = TRUE),
range_OD600 = max(OD600, na.rm = TRUE) - min(OD600, na.rm = TRUE)
)
ggplot(combined, aes(x=Time, y=OD600, group = Type, color = Type)) +geom_boxplot()+ geom_smooth(se=FALSE)+labs(color = "Type")+ theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) + scale_y_continuous(breaks = seq(0, 6, by = .5))+scale_color_manual(values=c("firebrick3", "burlywood3", "black"))+theme(legend.position = "bottom")
