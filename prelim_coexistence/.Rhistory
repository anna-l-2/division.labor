#combined
long <- function(df, sample_each = 8, n_samples = 4) {
df_long <- pivot_longer(df,
cols = everything(),
names_to = "Time",
values_to = "OD600")
df_long$Sample <- rep(1:n_samples, each = sample_each)
df_long$Time <- factor(df_long$Time,
levels = c("Day 1", "Day 3", "Day 5", "Day 7",
"Day 8", "Day 11", "Day 12", "Day 13"))
return(df_long)
}
serEpheK.l <-long(serEpheK)
serEtyrK.l <-long(serEtyrK)
serKpheE.l <-long(serKpheE)
serKtyrE.l <-long(serKtyrE)
serEpheK.l$Type <-c("serEpheK")
serEtyrK.l$Type <-c("serEtyrK")
serKpheE.l$Type <-c("serKpheE")
serKtyrE.l$Type <-c("serKtyrE")
serEpheK.l$Type2 <-c("serphe")
serEtyrK.l$Type2 <-c("sertyr")
serKpheE.l$Type2 <-c("serphe")
serKtyrE.l$Type2 <-c("sertyr")
coexist <- rbind(serEpheK.l, serEtyrK.l, serKpheE.l,serKtyrE.l)
coexist
ggplot(coexist, aes(x=Time, y=OD600, group = Type2, color = Type2)) +geom_point()+ geom_smooth()+labs(color = "Type", x = "Time (Day)")+ theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1)) + scale_y_continuous(breaks = seq(0, 6, by = .5)) #+geom_boxplot(aes(group = Time), width = 0.1, fill = NA, color = "black", outlier.shape = NA)
aov.coexist <-aov(OD600~Sample+Type2, data = coexist)
summary(aov.coexist)
TukeyHSD(aov.coexist)
